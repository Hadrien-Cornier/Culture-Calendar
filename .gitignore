# OpenClaw Claude Code runtime logs (do not commit)
.openclaw/claude-code/logs/

# Root-level pipeline logs (transient; do not commit)
/*.log

# SQLite sidecars (if any)
*.sqlite-shm
*.sqlite-wal
.long-run/active.pid
.long-run/_shim/
.long-run/*/events.log
.long-run/*/task-*.log
.long-run/*/task-result*.json

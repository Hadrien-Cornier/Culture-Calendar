#!/usr/bin/env bash
# Pre-push gates:
#   1. Repo-minimalism gate — runs on every push. Validates that
#      personas/code-review/repo-minimalism.json is present and parses,
#      then announces the gate. The LLM evaluation itself is driven by
#      the long-run council harness (~/.claude/skills/long-run/scripts/
#      task-judge.sh) during long-runs; for stand-alone pushes the spec
#      governs reviewer behavior at scorecard time. The gate exits
#      non-zero if the spec is missing or malformed (misconfigured).
#   2. Persona gate (Gate B) — blocks pushes when any outgoing commit
#      subject contains the literal [persona-gate] marker and the
#      live-site LLM persona council (run against a local server) FAILs.
#
# Activation (per-clone; not enforced globally):
#
#   git config core.hooksPath .githooks
#
# See CLAUDE.md §Persona critique gate for the full workflow.
#
# Git passes lines like "<local ref> <local oid> <remote ref> <remote oid>"
# on stdin (one per refspec). For each non-zero local oid, iterate the
# commits in $remote..$local and check their subjects.

set -eu

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

marker='[persona-gate]'
minimalism_persona="personas/council/repo-minimalism.json"
capture_script="scripts/capture_live_site_context.py"
council_judge=".council/llm-council/scripts/council-judge.sh"
council_manifest=".council/live-site.json"

# Resolve a Python interpreter once. Used by both gates below.
if [ -x ".venv/bin/python" ]; then
  py=".venv/bin/python"
else
  py="$(command -v python3 || command -v python || true)"
fi

# Walk every refspec on stdin, collecting outgoing ranges and any commits
# tagged with the [persona-gate] marker.
ranges=()
tagged_commits=()
while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    continue
  fi
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    base=$(git merge-base "$local_sha" origin/main 2>/dev/null || echo "")
    if [ -n "$base" ]; then
      range="$base..$local_sha"
    else
      range="$local_sha"
    fi
  else
    range="$remote_sha..$local_sha"
  fi
  ranges+=("$range")

  while IFS= read -r sha; do
    [ -z "$sha" ] && continue
    tagged_commits+=("$sha")
  done < <(git log --format='%H %s' "$range" 2>/dev/null | awk -v m="$marker" 'index($0, m) { print $1 }')
done

# Repo-minimalism gate (every push, regardless of [persona-gate] tag).
if [ ${#ranges[@]} -gt 0 ]; then
  if [ ! -f "$minimalism_persona" ]; then
    echo "[pre-push] $minimalism_persona missing; minimalism gate cannot run." >&2
    exit 1
  fi
  if [ -n "$py" ] && ! "$py" -c "import json,sys; json.load(open(sys.argv[1]))" "$minimalism_persona" >/dev/null 2>&1; then
    echo "[pre-push] $minimalism_persona is not valid JSON; minimalism gate misconfigured." >&2
    exit 1
  fi
  echo "[pre-push] repo-minimalism gate active: $minimalism_persona"
fi

# Persona gate (Gate B) — only when at least one outgoing commit is tagged.
if [ ${#tagged_commits[@]} -eq 0 ]; then
  exit 0
fi

echo "[pre-push] ${#tagged_commits[@]} commit(s) tagged $marker; running live-site council gate..."
for sha in "${tagged_commits[@]}"; do
  short=$(git rev-parse --short "$sha")
  echo "  - $short: $(git log -1 --format='%s' "$sha")"
done

# The cross-family council calls OpenRouter. Without a key (e.g. a contributor
# who hasn't set one), degrade gracefully so the push isn't hard-blocked — CI
# and the long-run harness still enforce the gate with the key present.
if [ -z "${OPENROUTER_API_KEY:-}" ]; then
  echo "[pre-push] OPENROUTER_API_KEY unset; skipping live-site council gate." >&2
  echo "[pre-push] (export it locally to enforce cross-family UX review before pushing.)" >&2
  exit 0
fi
if [ -z "$py" ]; then
  echo "[pre-push] no python interpreter found; cannot capture live-site context." >&2
  exit 1
fi
if [ ! -f "$capture_script" ] || [ ! -f "$council_judge" ] || [ ! -f "$council_manifest" ]; then
  echo "[pre-push] council components missing; skipping live-site gate." >&2
  echo "           (need $capture_script, $council_judge, $council_manifest)" >&2
  exit 0
fi

# 1) Capture the deployed-site structural ground truth (spins a localhost
#    http.server rooted at docs/ and runs the personas/live-site-specs asserts).
if ! "$py" "$capture_script" \
      --specs-dir personas/live-site-specs \
      --docs-dir docs \
      --out .council/live-site-context.md; then
  echo "[pre-push] live-site capture failed; skipping council gate (not blocking)." >&2
  exit 0
fi

# 2) Judge the captured context with the cross-family council (Anthropic excluded).
rc=0
bash "$council_judge" \
  --council "$council_manifest" \
  --context-file .council/live-site-context.md \
  --reviews-dir .council/live-site-reviews || rc=$?
case "$rc" in
  0)
    echo "[pre-push] live-site council ACCEPT; proceeding with push."
    exit 0 ;;
  2)
    echo "[pre-push] live-site council ESCALATE (all abstained / dispatch failed)." >&2
    echo "Review .council/live-site-reviews/ then 'git push --no-verify' if intended." >&2
    exit 1 ;;
  *)
    echo "" >&2
    echo "[pre-push] PUSH BLOCKED — live-site council REJECT." >&2
    echo "Inspect .council/live-site-reviews/aggregate-verdict.json, address the" >&2
    echo "findings, and amend the commit. Emergency override: git push --no-verify" >&2
    exit 1 ;;
esac
